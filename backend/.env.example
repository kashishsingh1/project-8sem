# Backend Environment Variables
PORT=5001

# Neon Serverless PostgreSQL — Use the POOLED connection string from Neon console
# (ends with ?sslmode=require, hostname contains -pooler)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require

# Gemini API Keys (add as many as you need for failover)
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_API_KEY_3=your_third_gemini_api_key_here
